{
    "name": "ace-account-manager",
    "displayName": "Windsurf 账号管理助手",
    "description": "Windsurf IDE 账号无感切换管理工具",
    "version": "1.2.2",
    "publisher": "AceTools",
    "repository": {
        "type": "git",
        "url": "https://github.com/juststrol/windsurf_account_manager"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "icon": "icon.png",
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "aceSwitch",
                    "title": "账号切换",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "aceSwitch": [
                {
                    "type": "webview",
                    "id": "aceSwitch.accountPanel",
                    "name": "账号管理"
                }
            ]
        },
        "commands": [
            {
                "command": "aceSwitch.switchAccount",
                "title": "切换账号",
                "category": "AceSwitch",
                "icon": "$(arrow-swap)"
            },
            {
                "command": "aceSwitch.addAccount",
                "title": "添加账号",
                "category": "AceSwitch",
                "icon": "$(add)"
            },
            {
                "command": "aceSwitch.listAccounts",
                "title": "管理账号",
                "category": "AceSwitch"
            },
            {
                "command": "aceSwitch.showCurrentAccount",
                "title": "查看当前账号",
                "category": "AceSwitch"
            },
            {
                "command": "aceSwitch.removeAccount",
                "title": "删除账号",
                "category": "AceSwitch"
            },
            {
                "command": "aceSwitch.refreshPanel",
                "title": "刷新面板",
                "category": "AceSwitch",
                "icon": "$(refresh)"
            },
            {
                "command": "aceSwitch.switchNextAccount",
                "title": "切换下一个账号",
                "category": "AceSwitch",
                "icon": "$(arrow-right)"
            }
        ],
        "keybindings": [
            {
                "command": "aceSwitch.switchNextAccount",
                "key": "ctrl+alt+k",
                "mac": "cmd+alt+k",
                "when": "true"
            }
        ],
        "configuration": {
            "title": "账号管理助手",
            "properties": {
                "aceSwitch.refreshOnSwitch": {
                    "type": "boolean",
                    "default": true,
                    "description": "切换账号后是否刷新窗口"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "echo 'skip compile'",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/uuid": "^9.0.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "sql.js": "^1.10.3",
        "uuid": "^9.0.1"
    }
}